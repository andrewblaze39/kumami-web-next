rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /research-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /news-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /blog-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /education-thumbnails/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /education-assets/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /community-events/{fileName} {                                                                                                                                                                                                         
      allow read: if true;                                                                                                                                                                                                                       
      allow write: if request.auth != null && request.auth.token.isAdmin == true;                                                                                                                                                                
    }    

    match /ai-module-thumbnails/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /game-images/{path=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /alpha-room/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /marketAnalysisImages/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Partner logos
    match /partner-logos/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Partner article images (Partner Portal)
    match /partner-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Keep other paths locked down
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
